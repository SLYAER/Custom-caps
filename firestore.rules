rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email in ['loveranger900@gmail.com', 'adarshray142@gmail.com', 'scam7737@gmail.com']);
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Schemas ---
    function isValidItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
          && data.price is number && data.price >= 0;
    }
    function isValidOrder(data) {
      return data.customerEmail is string && data.customerEmail.size() > 5 && data.customerEmail.size() < 100
          && data.items is list && data.items.size() > 0 && data.items.size() < 50
          && data.total is number && data.total >= 0
          && data.status is string && (data.status == 'pending' || data.status == 'confirmed');
    }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /orders/{orderId} {
      allow read: if isSignedIn() && (request.auth.token.email == resource.data.customerEmail || isAdmin());
      allow list: if isAdmin(); // Administrative list only
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
