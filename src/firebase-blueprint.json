{
  "entities": {
    "Item": {
      "title": "Item",
      "description": "Product item for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["customerEmail", "items", "total"]
    }
  },
  "firestore": {
    "items/{itemId}": {
      "schema": "Item",
      "description": "Collection of saleable items"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
